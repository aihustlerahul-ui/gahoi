enable-pre-post-scripts=true

# React Native Gradle resolves packages from android/ via node; hoist RN tooling for pnpm.
public-hoist-pattern[]=*@react-native*
public-hoist-pattern[]=*react-native*
# Metro web bundler must resolve expo-router, babel runtime, etc. from apps/mobile/node_modules
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*@babel*
public-hoist-pattern[]=*@expo*
