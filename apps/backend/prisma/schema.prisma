generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String?
  role        String    @default("moderator")
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}

model Country {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  iso2     String    @unique @db.VarChar(2)
  states   State[]
  profiles Profile[]

  @@map("locations_country")
}

model State {
  id        Int     @id @default(autoincrement())
  name      String
  countryId Int
  cities    City[]
  country   Country @relation(fields: [countryId], references: [id])

  @@map("locations_state")
}

model City {
  id             Int       @id @default(autoincrement())
  name           String
  stateId        Int
  state          State     @relation(fields: [stateId], references: [id])
  livingProfiles Profile[] @relation("LivingCity")
  birthProfiles  Profile[] @relation("BirthCity")

  @@map("locations_city")
}

model Gotra {
  id           Int          @id @default(autoincrement())
  key          String       @unique
  name         String       @unique
  gotraHindi   String       @map("gotra_hindi")
  gotraEnglish String       @map("gotra_english")
  rishi        String?
  kuldevi      String?      @map("kuldevi")
  aaknaLinks   GotraAakna[]
  profiles     Profile[]

  @@map("gotras")
}

model AaknaMaster {
  id                    Int             @id @default(autoincrement())
  name                  String          @unique
  gotraLinks            GotraAakna[]
  profiles              Profile[]
  maternalUncleFamilies ProfileFamily[] @relation("MaternalUncleAakna")

  @@map("aakna_master")
}

model GotraAakna {
  gotraId       Int         @map("gotra_id")
  aaknaMasterId Int         @map("aakna_master_id")
  gotra         Gotra       @relation(fields: [gotraId], references: [id], onDelete: Cascade)
  aakna         AaknaMaster @relation(fields: [aaknaMasterId], references: [id], onDelete: Cascade)

  @@id([gotraId, aaknaMasterId])
  @@index([aaknaMasterId])
  @@map("gotra_aakna")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String?        @map("password_hash")
  preferredLanguage String         @default("en") @map("preferred_language")
  isEmailVerified   Boolean        @default(false) @map("is_email_verified")
  authProvider      String         @default("email_otp") @map("auth_provider")
  status            String         @default("Active")
  tier              String         @default("free")
  lastActiveAt      DateTime?      @map("last_active_at")
  termsAcceptedAt   DateTime?      @map("terms_accepted_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  expoPushToken     String?        @map("expo_push_token")
  otpRequests       OtpRequest[]
  profile           Profile?
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpRequest {
  id          String    @id @default(uuid())
  email       String
  otpHash     String    @map("otp_hash")
  attempts    Int       @default(0)
  lockedUntil DateTime? @map("locked_until")
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id])

  @@index([email])
  @@map("otp_requests")
}

model Profile {
  id                     String                     @id
  profileId              Int                        @unique @default(autoincrement()) @map("profile_id")
  firstName              String?                    @map("first_name")
  lastName               String?                    @map("last_name")
  gender                 String?
  gotraId                Int?                       @map("gotra_id")
  aaknaId                Int?                       @map("aakna_id")
  gotra                  String?
  aakna                  String?
  manglikStatus          String                     @default("Non-Manglik") @map("manglik_status")
  maritalStatus          String?                    @map("marital_status")
  dateOfBirth            DateTime?                  @map("date_of_birth")
  timeOfBirth            String?                    @map("time_of_birth")
  placeOfBirth           String?                    @map("place_of_birth")
  nakshatra              String?
  zodiac                 String?
  height_cm              Int?
  heightFt               Int?                       @map("height_ft")
  heightIn               Int?                       @map("height_in")
  weightKg               Float?                     @map("weight_kg")
  complexion             String?
  mobile                 String?
  mobileCountryCode      Int                        @default(91) @map("mobile_country_code")
  whatsapp               String?
  motherTongue           String?                    @map("mother_tongue")
  disability             String                     @default("No")
  profileCreatedBy       String?                    @map("profile_created_by")
  bloodGroup             String?                    @map("blood_group")
  dietaryHabit           String?                    @map("dietary_habit")
  birthCityId            Int?                       @map("birth_city_id")
  livingCityId           Int?                       @map("living_city_id")
  town                   String?
  nativeState            String?                    @map("native_state")
  adminStatus            String                     @default("pending") @map("admin_status")
  profileCompletenessPct Int                        @default(0) @map("profile_completeness_pct")
  isVerified             Boolean                    @default(false) @map("is_verified")
  aboutMe                String?                    @map("about_me")
  countryId              Int?                       @map("country_id")
  createdAt              DateTime                   @default(now()) @map("created_at")
  updatedAt              DateTime                   @updatedAt @map("updated_at")
  receivedInterests      Interest[]                 @relation("Receiver")
  sentInterests          Interest[]                 @relation("Sender")
  matchCandidates        MatchCandidate[]           @relation("MatchUser")
  blockedBy              ProfileBlock[]             @relation("Blocked")
  blocks                 ProfileBlock[]             @relation("Blocker")
  education              ProfileEducation?
  family                 ProfileFamily?
  gallery                ProfileGallery[]
  occupation             ProfileOccupation?
  preferences            ProfilePartnerPreferences?
  reports                ProfileReport[]            @relation("Reported")
  viewsReceived          ProfileView[]              @relation("Viewed")
  viewsGiven             ProfileView[]              @relation("Viewer")
  country                Country?                   @relation(fields: [countryId], references: [id])
  user                   User                       @relation(fields: [id], references: [id], onDelete: Cascade)
  birthCity              City?                      @relation("BirthCity", fields: [birthCityId], references: [id])
  livingCity             City?                      @relation("LivingCity", fields: [livingCityId], references: [id])
  gotraMaster            Gotra?                     @relation(fields: [gotraId], references: [id])
  selectedAakna          AaknaMaster?               @relation(fields: [aaknaId], references: [id])
  shortlisted            Shortlist[]                @relation("ShortlistOwner")
  shortlistedBy          Shortlist[]                @relation("ShortlistedProfile")
  successStories         SuccessStory[]

  @@index([gotraId], map: "idx_profiles_gotra_id")
  @@index([gender])
  @@index([gotra])
  @@index([height_cm], map: "idx_profiles_height")
  @@index([birthCityId], map: "idx_profiles_birth_city")
  @@index([livingCityId], map: "idx_profiles_city")
  @@index([maritalStatus], map: "idx_profiles_marital")
  @@index([manglikStatus], map: "idx_profiles_manglik")
  @@index([adminStatus], map: "idx_profiles_status")
  @@map("profiles")
}

model ProfileEducation {
  profileId         String  @id @map("profile_id")
  highestDegree     String? @map("highest_degree")
  fieldOfStudy      String? @map("field_of_study")
  institution       String?
  completionYear    Int?    @map("completion_year")
  educationalDetail String? @map("educational_detail")
  profile           Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_education")
}

model ProfileOccupation {
  profileId         String  @id @map("profile_id")
  occupationType    String? @map("occupation_type")
  jobTitle          String? @map("job_title")
  employer          String?
  occupationDetail  String? @map("occupation_detail")
  annualIncomeMin   Int?    @map("annual_income_min")
  annualIncomeMax   Int?    @map("annual_income_max")
  profile           Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([annualIncomeMin, annualIncomeMax], map: "idx_occupation_income")
  @@map("profile_occupation")
}

model ProfileFamily {
  profileId          String  @id @map("profile_id")
  fatherName         String? @map("father_name")
  parentMobile       String? @map("parent_mobile")
  fatherOccupation   String? @map("father_occupation")
  motherName         String? @map("mother_name")
  motherOccupation   String? @map("mother_occupation")
  siblings           Int?
  marriedBrothers    Int     @default(0) @map("married_brothers")
  unmarriedBrothers  Int     @default(0) @map("unmarried_brothers")
  marriedSisters     Int     @default(0) @map("married_sisters")
  unmarriedSisters   Int     @default(0) @map("unmarried_sisters")
  maternalUncleName      String?      @map("maternal_uncle_name")
  maternalUncleAakna     String?      @map("maternal_uncle_aakna")
  maternalUncleAaknaId   Int?         @map("maternal_uncle_aakna_id")
  maternalUncleAaknaMaster AaknaMaster? @relation("MaternalUncleAakna", fields: [maternalUncleAaknaId], references: [id])
  familyType         String? @map("family_type")
  familyStatus       String? @map("family_status")
  hasHouse           String? @map("has_house")
  hasCar             Boolean @default(false) @map("has_car")
  homeAddress        String? @map("home_address")
  permanentAddress   String? @map("permanent_address")
  profile            Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_family")
}

model ProfilePartnerPreferences {
  profileId          String   @id @map("profile_id")
  ageMin             Int?     @map("age_min")
  ageMax             Int?     @map("age_max")
  heightMinCm        Int?     @map("height_min_cm")
  heightMaxCm        Int?     @map("height_max_cm")
  heightMinFt        Int?     @map("height_min_ft")
  heightMinIn        Int?     @map("height_min_in")
  heightMaxFt        Int?     @map("height_max_ft")
  heightMaxIn        Int?     @map("height_max_in")
  maritalStatus      String[] @map("marital_status")
  educationMin       String?  @map("education_min")
  incomeMin          Int?     @map("income_min")
  manglikPreference  String?  @map("manglik_preference")
  excludeSameGotra   Boolean  @default(true) @map("exclude_same_gotra")
  preferredCityIds   Int[]    @map("preferred_city_ids")
  preferredCountries String[] @map("preferred_countries")
  updatedAt          DateTime @updatedAt @map("updated_at")
  profile            Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_partner_preferences")
}

model ProfileGallery {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  r2Key       String   @map("r2_key")
  visibility  String   @default("public")
  adminStatus String   @default("pending") @map("admin_status")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, sortOrder], map: "idx_gallery_profile")
  @@map("profile_gallery")
}

model Interest {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  status     String   @default("pending")
  message    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  receiver   Profile  @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     Profile  @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status], map: "idx_interests_receiver")
  @@index([senderId, status], map: "idx_interests_sender")
  @@map("interests")
}

model Shortlist {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  shortlistedId String   @map("shortlisted_id")
  createdAt     DateTime @default(now()) @map("created_at")
  owner         Profile  @relation("ShortlistOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  shortlisted   Profile  @relation("ShortlistedProfile", fields: [shortlistedId], references: [id], onDelete: Cascade)

  @@unique([ownerId, shortlistedId])
  @@map("shortlists")
}

model ProfileView {
  id        String   @id @default(uuid())
  viewerId  String   @map("viewer_id")
  viewedId  String   @map("viewed_id")
  createdAt DateTime @default(now()) @map("created_at")
  viewed    Profile  @relation("Viewed", fields: [viewedId], references: [id], onDelete: Cascade)
  viewer    Profile  @relation("Viewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([viewedId])
  @@map("profile_views")
}

model ProfileReport {
  id         String   @id @default(uuid())
  reporterId String   @map("reporter_id")
  reportedId String   @map("reported_id")
  reasonCode String   @map("reason_code")
  detail     String?
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")
  reported   Profile  @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@map("profile_reports")
}

model ProfileBlock {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")
  blocked   Profile  @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   Profile  @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("profile_blocks")
}

model MatchCandidate {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  candidateId String   @map("candidate_id")
  matchScore  Int      @map("match_score")
  kundliScore Int?     @map("kundli_score")
  computedAt  DateTime @default(now()) @map("computed_at")
  user        Profile  @relation("MatchUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, candidateId])
  @@index([userId, matchScore])
  @@map("match_candidates")
}

model SubscriptionPlan {
  id            String         @id @default(uuid())
  name          String
  nameHi        String         @map("name_hi")
  durationDays  Int            @map("duration_days")
  priceInr      Int            @map("price_inr")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  planId            String           @map("plan_id")
  razorpayOrderId   String           @unique @map("razorpay_order_id")
  razorpayPaymentId String?          @unique @map("razorpay_payment_id")
  status            String           @default("created")
  startsAt          DateTime?        @map("starts_at")
  expiresAt         DateTime?        @map("expires_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@map("subscriptions")
}

model PushCampaign {
  id             String   @id @default(uuid())
  title          String
  body           String
  data           Json?
  sentAt         DateTime @default(now()) @map("sent_at")
  recipientCount Int      @default(0) @map("recipient_count")

  @@map("push_campaigns")
}

model SuccessStory {
  id          String    @id @default(uuid())
  profileId   String    @map("profile_id")
  testimonial String
  photoR2Key  String?   @map("photo_r2_key")
  status      String    @default("pending")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("success_stories")
}

model AdminActionLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("admin_action_logs")
}
